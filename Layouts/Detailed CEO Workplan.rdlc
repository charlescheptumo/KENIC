                  <TextRuns>
                    <TextRun>
                      <Value EvaluationMode="Auto">QUALITY:  OUR AGENDA

PERFORMANCE CONTRACT

BETWEEN

THE COMMISSION SECRETARY/CHIEF EXECUTIVE OFFICER COMMISSION FOR UNIVERSITY EDUCATION</Value>
                      <Style>
                        <FontWeight>Bold</FontWeight>
                      </Style>
