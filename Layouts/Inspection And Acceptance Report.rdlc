                      <FontSize>12pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>) for the purpose of inspecting goods, works and services delivered in the Institute.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontSize>12pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
