          <Textbox Name="Textbox13">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Following my imminent retire on age grounds from the Public Service w.e.f from </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontSize>11pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=First(Fields!DateOfLeaving_Employee.Value, "DataSet_Result")</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontSize>11pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value> , I wish to hand over the following items which are under my custody.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontSize>11pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
