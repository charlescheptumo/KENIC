            <Textbox Name="Textbox92">
              <CanGrow>true</CanGrow>
              <KeepTogether>true</KeepTogether>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value EvaluationMode="Auto">This Performance Contract is entered into between the Head of Department, </Value>
                      <Style />
                    </TextRun>
                    <TextRun>
                      <Value EvaluationMode="Auto">=First(Fields!ResponsibilityCenterName_PerfomanceContractHeader.Value, "DataSet_Result")</Value>
                      <Style>
                        <FontWeight>Bold</FontWeight>
                      </Style>
                    </TextRun>
                    <TextRun>
                      <Value EvaluationMode="Auto"> on one part and the </Value>
                      <Style />
                    </TextRun>
